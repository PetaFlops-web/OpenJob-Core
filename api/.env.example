NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# PostgreSQL (Docker defaults)
PGHOST=postgres
PGPORT=5432
PGDATABASE=openjob_db
PGUSER=openjob
PGPASSWORD=openjob

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=openjob_db
POSTGRES_USER=openjob
POSTGRES_PASSWORD=openjob

# PostgreSQL from host machine (seed/local tooling)
# Use these when running scripts from the host against docker-compose.
HOST_PGHOST=localhost
HOST_PGPORT=5433

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=openjob_redis_secret

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# JWT — use long random secrets in production
ACCESS_TOKEN_KEY=change_me_access_token_secret_min_32_chars
REFRESH_TOKEN_KEY=change_me_refresh_token_secret_min_32_chars

# SMTP / email consumer
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@openjob.dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000
API_RATE_LIMIT_MAX_REQUESTS=5000
AUTH_RATE_LIMIT_MAX_REQUESTS=100

# ATS Flask service
ATS_ML_API_URL=http://ats-ml:5000
ATS_ML_API_KEY=your_ats_ml_api_key

# Docker entrypoint migrations: auto | true | false
RUN_MIGRATIONS=auto

# Firebase Admin (optional, required only for POST /firebase/login)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
